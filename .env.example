# Server address (default: :8080)
ADDR=:8080

# SQLite database file path (default: plink.db)
DB_PATH=plink.db

# Admin password — required, no default
ADMIN_PASSWORD=

# Environment: set to "production" to enable Secure cookie flag (requires HTTPS)
APP_ENV=development

# Admin path — set this to something hard to guess (default: admin)
# Admin will be accessible at /<ADMIN_PATH>/login
# Example: ADMIN_PATH=some-random-string
ADMIN_PATH=
