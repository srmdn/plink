[Unit]
Description=plink link shortener
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/plink
EnvironmentFile=/opt/plink/.env
ExecStart=/opt/plink/plink
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/opt/plink

[Install]
WantedBy=multi-user.target
